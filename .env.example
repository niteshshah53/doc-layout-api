# .env.example — copy to .env and adjust
# .env is gitignored so secrets never hit version control

# API
APP_NAME="Document Layout Detection API"
APP_VERSION="1.0.0"
DEBUG=false

# Model
MODEL_SCORE_THRESHOLD=0.5
DEVICE=cuda              # "cuda" or "cpu"

# Inference
MAX_IMAGE_SIZE=1024      # resize longest edge to this (pixels)
MAX_FILE_SIZE_MB=10

# Server
HOST=0.0.0.0
PORT=8000
